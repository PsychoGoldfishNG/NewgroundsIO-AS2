	line = this['score_'+i];

	if (i >= _parent['scores'].length) {
		line.gotoAndStop(3);
	} else {
		score = _parent['scores'][i];
		if (i%2 === 0) line.gotoAndStop(2);

		line.index.text = (i+1)+".";
		line.username.text = score.user.name;
		line.score.text = score.formatted_value;

		line.userpage = score.user.url;
	}
}

stop();]]></script>
