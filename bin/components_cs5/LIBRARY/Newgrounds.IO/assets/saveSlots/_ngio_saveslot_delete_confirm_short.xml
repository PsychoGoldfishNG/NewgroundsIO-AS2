                <script><![CDATA[if (this.bar === undefined) this.bar = null;
if (this.slot_id === undefined) this.slot_id = -1;

this.callbacks = {
	clear: 'onSlotDeleteConfirmed',
	replace: 'onSlotReplaceConfirmed'
};

this.messages = {
	clear: 'Remove Save File?',
	replace: 'Ovewrite Save File?'
};

this.action = 'clear';

var targetComponent = this._parent;
var _this = this;

this.confirmBtn.onRelease = function() {
	_this._visible = false;
	targetComponent[_this.callbacks[_this.action]].call(targetComponent, _this.slot_id, _this.bar);
};

this.cancelBtn.onRelease = function() {
	_this._visible = false;
};

this.show = function(action) {
	this.action = action === 'clear' ? 'clear':'replace';
	this._visible = true;
	this.message.text = this.messages[this.action];
}

this._visible = false;

stop();]]></script>
