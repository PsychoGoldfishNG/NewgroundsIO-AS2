              <Actionscript>
                <script><![CDATA[// this test works better using raw string data
_parent['saveSlotManager'].use_raw = true;

// set up our handlers once
if (this.ready === undefined) {
	this.ready = true;

	var _this = this;

	// refreshes what is displayed in the component
	function resetComponent():Void {
		_this._parent['saveSlotManager'].setData(null);
		_this.dataText.text = "";

		// pop this to the error frame just to unload any information
		_this._parent['saveSlotManager'].gotoAndStop('error');

		// go back to the display frame to re-render everything
		_this._parent['saveSlotManager'].gotoAndStop('display');
	}

	// force a visual refresh of the component when reset is clicked
	resetBtn.onRelease = function() {
		resetComponent();
	};

	// handle when data is loaded from the slot manager component
	_parent['saveSlotManager'].onSlotLoaded = function(_data, error) {
		// all we really want to do is pop the loaded text into our text input
		_this.dataText.text = _data ? _data : "No Data Found.";
	};

	// handle when data is saved from the slot manager component
	_parent['saveSlotManager'].onSlotSaved = function(error) {
		// all we really want to do is clear the input and reset the component
		resetComponent();
		_this.dataText.text = "Saved!";
	};

	// catch when someone types something
	this.dataText.onChanged = function() {
		_this._parent['saveSlotManager'].setData(this.text);
	};
}

if (_parent['saveSlotManager'].action !== 'Load Data') {
	this.gotoAndStop('save_mode');
}

saveModeBtn.onRelease = function() {
	_parent['saveSlotManager'].action = 'Save Data';
	resetComponent();
	this._parent.gotoAndStop('save_mode');
};

stop();]]></script>
