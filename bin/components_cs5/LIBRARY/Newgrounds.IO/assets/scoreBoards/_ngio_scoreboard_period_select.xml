      <layers>
        <DOMLayer name="Layer 1" color="#4FFF4F" current="true" isSelected="true">
          <frames>
            <DOMFrame index="0" keyMode="9728">
              <Actionscript>
                <script><![CDATA[// extract the period value from the movieclip's identifier name
this.period = this._name.split("_").pop();

// if this is the currently selected button, go to the next frame.
if (_parent['period'] === this.period) {
	gotoAndStop(2);

// otherwise set the button up
} else {
	var parentRef = _parent;
	var selfRef = this;

	btn.onRelease = function() {
		parentRef.refreshBoard({period:selfRef.period});
	};

}

stop();]]></script>
