<DOMSymbolItem xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://ns.adobe.com/xfl/2008/" name="Newgrounds.IO/assets/scoreBoards/Scoreboard Tester" itemID="6996124a-00000383" lastModified="1771902825">
  <timeline>
    <DOMTimeline name="Scoreboard Tester">
      <layers>
        <DOMLayer name="Layer 1" color="#4FFF4F" current="true" isSelected="true">
          <frames>
            <DOMFrame index="0" keyMode="9728">
              <Actionscript>
                <script><![CDATA[var _this = this;
var current_board_id:Number;

post_btn.onRelease = function() {

	var tag = null; // if you want to test a specific tag, change this

	// check for empty inputs
	if (_this.score_input.text.length < 1 || _this.board_id.text.length < 1) return;

	current_board_id = Number(_this.board_id.text);
	var score = Number(_this.score_input.text);

	var board = NGIO.getScoreBoard(current_board_id);

	if (!board) throw new Error("Couldn't find a board with that ID");

	// post the score!
	// you don't need to use a callback here, but we want to refresh the scoreboard after our post is saved
	board.postScore(score, tag, _this.onScorePosted, _this);
};

this.onScorePosted = function(score, error) {
	trace('Score posted with value: '+score.formatted_value);

	// the scoreboard is only meant to refresh when a filter value is changed.
	// we're going to do a little hack to trick it into thinking we were looking at board id #0
	// so the refreh call below will actuallytrigger a new load.
	_parent['ngioScoreBoard'].board_id = 0;

	// tell the scoreboard to refresh using the board id we just posted to
	_parent['ngioScoreBoard'].refreshBoard({board_id:current_board_id});
}]]></script>
