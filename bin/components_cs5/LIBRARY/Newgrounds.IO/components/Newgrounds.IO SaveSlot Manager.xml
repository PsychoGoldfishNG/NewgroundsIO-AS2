<DOMComponentItem xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://ns.adobe.com/xfl/2008/" name="Newgrounds.IO/components/Newgrounds.IO SaveSlot Manager" itemID="6995e11d-000002d6" lastModified="1772126009" lastUniqueIdentifier="10" displayAsComponent="false" customIconID="0" descriptionType="text" persistLivePreview11="true" symbolDescription="Displays SaveSlot informaton and allows the user to load and clear slots" editFrameIndex="1" requiredMinimumPlayerVersion="0" requiredMinimumASVersion="0" parametersAreLocked="true">
