              <Actionscript>
                <script><![CDATA[this.closeBtn.onRelease = function() {
	this._parent.gotoAndStop(1);
};

// todo call onScrollUp/Down from scroll_up/down click
function showList() {

	// self referecee for nested functions
	var _this = this;

	// grab our scoreboards
	this.boards = NGIO.getScoreBoards();

	// we have 15 rows that scoreboard names can pop into
	this.max_visible_scores = 15;

	// by default we'll use frame 1 for our options, wich makes room for the scrollbar
	this.item_frame = 1;

	// how many scoreboard names are hidden at any given time?
	this.num_overflow_scores = this.boards ? this.boards.length - this.max_visible_scores : 0;
	if (this.num_overflow_scores < 0) this.num_overflow_scores = 0;

	// the index of the top item in our scoreboard list
	this.scroll_index = 0;

	// the distance the scrollbar canmove
	this.scroll_range = this.scroll_bottom._y - this.scroll_bar._y;

	// the highest position the bar can scroll to
	this.scroll_min = this.scroll_bar._y;

	// the lowest position the bar can scroll to
	this.scroll_max = this.scroll_min + this.scroll_range;

	// we don't have enough scores to need a scrollbar
	if (this.num_overflow_scores < 1) {

		// the scoreboard option clips will use frame 2 where they can have wider text
		this.item_frame = 2;

		// calculate some sizes we'll use to scale the dropdown background
		var top = this.background._y;
		var pad = board_0._y - top;
		var gap = board_1._y - board_0._y;

		// shrink the dropdown background as needed
		this.background.height = Math.ceil((gap * this.boards.length) + (pad * 2));

		// hide the scrolling elements
		this.scroll_up._visible = false;
		this.scroll_bar._visible = false;
		this.scroll_down._visible = false;
	}

	// this element is used to set up the scrolling area, but we don't want to actualy see it
	this.scroll_bottom._visible = false;

	this.onScrollDown = function() {
		var max = _this.boards.length - this.max_visible_scores;
		_this.scroll_index++;
		if (_this.scroll_index > max) _this.scroll_index = max;
		_this.updateOptions();
	}

	this.onScrollUp = function() {
		_this.scroll_index--;
		if (_this.scroll_index < 0) _this.scroll_index = 0;
		_this.updateOptions();
	}

	// scrollbar code:
	var interval;
	var timeout;

	// listen for the mouse to be pressed on the scroll down button
	this.scroll_down.onPress = function() {
		clearInterval(interval);
		clearTimeout(timeout);

		// do a single row scroll instantly
		_this.onScrollDown();

		// wait a short duration....
		timeout = setTimeout(function() {

			// ...and scroll a line every tick of this interval
			interval = setInterval(function() {
				_this.onScrollDown();
			}, 75);
		}, 200);
	};

	// mouse release or rolling off the button will stop scrolling
	this.scroll_down.onRelease = function() {
		clearInterval(interval);
		clearTimeout(timeout);
	};
	this.scroll_down.onRollOut = function() {
		clearInterval(interval);
		clearTimeout(timeout);
	};

	// listen for the mouse to be pressed on the scroll up button
	this.scroll_up.onPress = function() {
		clearInterval(interval);
		clearTimeout(timeout);

		// do a single row scroll instantly
		_this.onScrollUp();

		// wait a short duration....
		timeout = setTimeout(function() {

			// ...and scroll a line every tick of this interval
			interval = setInterval(function() {
				_this.onScrollUp();
			}, 75);
		}, 200);
	};

	// mouse release or rolling off the button will stop scrolling
	this.scroll_up.onRelease = function() {
		clearInterval(interval);
		clearTimeout(timeout);
	};
	this.scroll_up.onRollOut = function() {
		clearInterval(interval);
		clearTimeout(timeout);
	};

	// handle dragging the scroll bar

	// how far is the mouse from the top of the bar?
	var mouse_offset:Number = 0;
	var scrolling = false;

	function startScrolling() {
		if (scrolling) return;
		mouse_offset = _this._ymouse - _this.scroll_bar._y;
		scrolling = true;
		_this.onEnterFrame = updateScrolling;
		_this.onMouseUp = stopScrolling;
	}

	function stopScrolling() {
		_this.onMouseUp = null;
		_this.onEnterFrame = null;
		scrolling = false;
	}

	function updateScrolling() {
		// we shouldn't be hitting this if scrolling is off
		if (!scrolling) return stopScrolling();

		// remember where the scroll bar is right now
		var last = _this.scroll_bar._y;

		// move the scrollbar to line up with any mouse movement
		_this.scroll_bar._y = _this._ymouse - mouse_offset;

		// lock it to our bounds
		if (_this.scroll_bar._y < _this.scroll_min) _this.scroll_bar._y = _this.scroll_min;
		else if (_this.scroll_bar._y > _this.scroll_max) _this.scroll_bar._y = _this.scroll_max;

		// if it's in the same position we started at, do nothing
		if (last === _this.scroll_bar._y) return;

		// how far along the scroll area are we?
		var scroll_at = _this.scroll_bar._y - _this.scroll_min;
		var percent = scroll_at / _this.scroll_range;

		// what should the top index be
		_this.scroll_index = Math.round(_this.num_overflow_scores * percent);
		_this.updateOptions();
	}

	this.scroll_bar.onPress = function() {
		startScrolling();
	};


	this.select = function(board_id) {
		this._parent['refreshBoard']({board_id:board_id});
		this.gotoAndStop(1);
	}

	this.updateOptions = function() {
		var board, line;

		if (this.boards.length > this.max_visible_scores) {
			var span = this.boards.length - this.max_visible_scores;
			var percent = this.scroll_index/span;
			this.scroll_bar._y = this.scroll_min + (this.scroll_range * percent);
		}

		for(var i=0; i<this.max_visible_scores; i++) {
			board = this.boards[i+this.scroll_index];
			line = this['board_'+i];

			if (board === undefined) {
				line.gotoAndStop(3);

			} else {
				line.gotoAndStop(this.item_frame);
				line.board_id = board.id;
				line.selected_board.text = board.name;
			}
		}
	}

	this.updateOptions();
}

showList.call(this);
stop();]]></script>
